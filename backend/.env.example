# Server
PORT=8081
HOST=0.0.0.0

# Auth / DB
JWT_SECRET=
TOKEN_TTL_HOURS=168
DB_PATH=./nicefilm.db

# OpenSubtitles (optional — subtitle search/download disabled if unset)
OPENSUBTITLES_API_KEY=
